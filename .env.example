# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aideasboom
DB_USER=postgres
DB_PASSWORD=your_password_here

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Redis (para BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google APIs
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json
SHEET_APROBACIONES_ID=your_master_sheet_id
DRIVE_ROOT_FOLDER_ID=your_drive_root_folder_id
